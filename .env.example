# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# QuickBooks
ACCOUNTING_PROVIDER=iif
CONDUCTOR_API_KEY=
CONDUCTOR_END_USER_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Fingerlakes Farms

# Email
RESEND_API_KEY=
RESEND_FROM="Fingerlakes Farms <orders@ilovenyfarms.com>"

# Twilio (phone OTP + SMS bridge)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_SECRET=
# Local-dev escape hatch for inbound SMS when you can't sign requests.
# NEVER set this in any deployed environment (preview / staging / prod).
ALLOW_UNSIGNED_TWILIO=

# Admin "view as buyer" cookie HMAC secret. Defaults to SUPABASE_SERVICE_ROLE_KEY
# when unset, but you should set this to a separate random string in production
# so rotating one doesn't invalidate the other.
IMPERSONATION_SECRET=

# Web Push (PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@ilovenyfarms.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Cron job auth (Vercel Cron adds header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
