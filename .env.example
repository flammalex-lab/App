# SEC EDGAR requires a descriptive User-Agent identifying you.
# See: https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT="Your Name your.email@example.com"

# Anthropic API key for LLM-driven filing analysis
ANTHROPIC_API_KEY=

# Default model for filing analysis (Haiku is fast+cheap; Sonnet for nuanced reads)
ALPHA_MODEL_FAST=claude-haiku-4-5-20251001
ALPHA_MODEL_DEEP=claude-sonnet-4-6

# Data directory
ALPHA_DATA_DIR=./data

# Minimum market cap (USD) for the universe
ALPHA_MIN_MCAP=20000000

# Digest delivery
ALPHA_DIGEST_PATH=./data/reports
