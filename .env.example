# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# QuickBooks
ACCOUNTING_PROVIDER=iif
CONDUCTOR_API_KEY=
CONDUCTOR_END_USER_ID=

# App
# Production: https://order.ilovenyfarms.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Fingerlakes Farms

# Email
RESEND_API_KEY=
RESEND_FROM="Fingerlakes Farms <orders@ilovenyfarms.com>"

# Twilio (phone OTP + SMS bridge)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_SECRET=
# Local-dev escape hatch for inbound SMS when you can't sign requests.
# NEVER set this in any deployed environment (preview / staging / prod).
ALLOW_UNSIGNED_TWILIO=

# Admin "view as buyer" cookie HMAC secret. REQUIRED in production —
# the dev-only fallback to SUPABASE_SERVICE_ROLE_KEY means a leaked
# service-role key (env dump, deploy log) becomes equivalent to the
# ability to forge impersonation cookies for any non-admin profile.
# Generate with: `openssl rand -base64 32`
IMPERSONATION_SECRET=

# Web Push (PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@ilovenyfarms.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Cron job auth (Vercel Cron adds header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# /api/health gate. When unset, falls back to CRON_SECRET — convenient,
# but it means a leaked CRON_SECRET also unlocks health-endpoint env
# enumeration. Set this to its own random value if you want them
# decoupled (recommended for prod).
HEALTH_TOKEN=

# Sentry — when unset, the SDK no-ops (no events queued, no network
# calls). Grab the DSN from Sentry → Settings → Projects → <project> →
# Client Keys (DSN). Leave blank in dev so the local console stays
# clean. Source-map upload also requires SENTRY_ORG, SENTRY_PROJECT,
# and SENTRY_AUTH_TOKEN as build-time env vars on Vercel.
NEXT_PUBLIC_SENTRY_DSN=
